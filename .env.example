NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
QUEUE_MEMORY_LIMIT=25
QUEUE_DEFERRED_LIMIT=1000
QUEUE_RECENT_FAILURE_LIMIT=20
QUEUE_RECENT_REJECTION_LIMIT=20
QUEUE_DB_PATH=.queue-data/alerts.sqlite
AUDIO_OUTPUT_DIR=.audio-output
PLAYER_KIND=vlc
PLAYER_COMMAND=C:\Program Files\VideoLAN\VLC\vlc.exe
PLAYER_TIMEOUT_MS=30000
TTS_MODE=stub
ELEVENLABS_API_KEY=<YOUR_ELEVENLABS_API_KEY_HERE>
ELEVENLABS_VOICE_ID=<YOUR_ELEVENLABS_VOICE_ID_HERE>
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_TIMEOUT_MS=15000
SHUTDOWN_POLICY=preserve-pending