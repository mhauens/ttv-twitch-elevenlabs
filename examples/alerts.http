@baseUrl = http://127.0.0.1:3000

### Submit an alert
POST {{baseUrl}}/api/v1/alerts
Content-Type: application/json

{
  "source": "local",
  "alertType": "cheer",
  "dedupeKey": "example-1",
  "payload": {
    "userName": "tester",
    "message": "hello queue"
  }
}

### Mix It Up Web Request payload
POST {{baseUrl}}/api/v1/alerts
Content-Type: application/json

{
  "source": "mixitup",
  "alertType": "follow",
  "payload": {
    "userName": "$username",
    "message": "Willkommen im Stream"
  }
}

### Streamer.bot canonical payload
# See examples/streamerbot-alert.mjs for the official scripted POST flow.
POST {{baseUrl}}/api/v1/alerts
Content-Type: application/json

{
  "source": "streamerbot",
  "alertType": "raid",
  "payload": {
    "userName": "raid-leader",
    "message": "Raid erfolgreich uebernommen"
  }
}

### Submit the same dedupe key again
POST {{baseUrl}}/api/v1/alerts
Content-Type: application/json

{
  "source": "local",
  "alertType": "cheer",
  "dedupeKey": "example-1",
  "payload": {
    "userName": "tester",
    "message": "duplicate request"
  }
}

### Inspect queue status
GET {{baseUrl}}/api/v1/queue

### Inspect service health
GET {{baseUrl}}/api/v1/health